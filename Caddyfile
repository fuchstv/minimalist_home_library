:80 {
    # Proxy API requests to the backend, preserving the /api prefix
    handle /api/* {
        reverse_proxy backend:80
    }

    # Proxy upload requests to the backend
    handle /uploads/* {
        reverse_proxy backend:80
    }

    # Proxy all other requests to the frontend (Nginx serving static files)
    handle /* {
        reverse_proxy frontend:80
    }
}
